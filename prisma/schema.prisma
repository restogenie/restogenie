generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               Int           @id @default(autoincrement())
  email            String        @unique
  password_hash    String
  name             String
  phone            String?
  agreed_terms     Boolean       @default(false)
  agreed_privacy   Boolean       @default(false)
  agreed_marketing Boolean       @default(false)
  created_at       DateTime      @default(now())
  store_members    StoreMember[]
  stores           Store[]
  ai_api_keys      AiApiKey[]
  chat_sessions    ChatSession[]

  @@map("users")
}

model StoreMember {
  id         Int      @id @default(autoincrement())
  store_id   Int
  user_id    Int
  role       Role     @default(STAFF)
  created_at DateTime @default(now())
  store      Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([store_id, user_id])
  @@map("store_members")
}

model Store {
  id                    Int             @id @default(autoincrement())
  user_id               Int
  name                  String
  business_number       String
  business_condition    String?
  business_type         String?
  opening_date          DateTime?       @db.Date
  phone                 String?
  created_at            DateTime        @default(now())
  billing_key           String?
  subscription_end_date DateTime?
  subscription_status   String          @default("TRIAL")
  menu_mappings         MenuMapping[]
  pos_connections       PosConnection[]
  sales                 Sale[]
  members               StoreMember[]
  user                  User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  system_logs           SystemLog[]
  foot_traffics         FootTraffic[]
  cctv_connections      CctvConnection[]
  chat_sessions         ChatSession[]
  weekly_reports        WeeklyReport[]

  @@index([user_id])
  @@map("stores")
}

model PosConnection {
  id          Int      @id @default(autoincrement())
  store_id    Int
  vendor      String
  auth_code_1 String?
  auth_code_2 String?
  auth_code_3 String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  sync_status String   @default("PENDING")
  store       Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@unique([store_id, vendor])
  @@map("pos_connections")
}

model Sale {
  store_id                     Int
  provider                     String         @default("payhere")
  oid                          String
  business_date                DateTime       @db.Date
  created_at                   DateTime
  order_name                   String?
  order_from                   String?
  order_status                 String?
  ordered_amount               Float          @default(0.0)
  paid_amount                  Float          @default(0.0)
  point_used_amount            Float          @default(0.0)
  customer_point_earned        Float          @default(0.0)
  prepaid_used_amount          Float          @default(0.0)
  discount_amount              Float          @default(0.0)
  refunded_amount              Float          @default(0.0)
  customer_uid                 String?
  customer_mobile_phone_number String?
  delivery_app                 String?
  delivery_order_no            String?
  menu_items                   MenuLineItem[]
  store                        Store          @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@id([store_id, provider, oid])
  @@index([store_id])
  @@index([provider])
  @@index([business_date])
  @@map("sales_db")
}

model MenuLineItem {
  id            Int       @id @default(autoincrement())
  unique_oid    String    @unique @default(uuid())
  store_id      Int
  provider      String
  oid           String
  main_item_seq Int?
  created_at    DateTime?
  product_name  String?
  product_price Float     @default(0.0)
  quantity      Int       @default(0)
  total_price   Float     @default(0.0)
  option_name   String?
  option_seq    Int?
  option_id     String?
  option_price  Float?
  sale          Sale      @relation(fields: [store_id, provider, oid], references: [store_id, provider, oid], onDelete: Cascade)

  @@index([store_id, provider, oid])
  @@map("menu_db")
}

model MenuMapping {
  id              Int       @id @default(autoincrement())
  provider        String
  original_name   String
  normalized_name String
  created_at      DateTime? @default(now())
  updated_at      DateTime? @updatedAt
  store_id        Int
  custom_id       String?
  is_option       Boolean   @default(false)
  store           Store     @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@unique([store_id, provider, original_name])
  @@index([store_id])
  @@index([normalized_name])
  @@map("menu_mapping_db")
}

model SystemLog {
  id         Int      @id @default(autoincrement())
  level      String   @default("INFO") @db.VarChar(50)
  source     String   @db.VarChar(100)
  message    String
  created_at DateTime @default(now())
  store_id   Int?
  store      Store?   @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([store_id])
  @@map("system_logs")
}

model FootTraffic {
  id             Int      @id @default(autoincrement())
  store_id       Int
  widget_name    String   
  age_group      String?
  gender         String?
  visit_date     DateTime @db.Date 
  visit_time     String?  
  visit_count    Int      @default(1)
  sync_timestamp DateTime @default(now())
  store          Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([store_id, visit_date])
  @@index([widget_name])
  @@map("foot_traffics")
}

model CctvConnection {
  id           Int      @id @default(autoincrement())
  store_id     Int      @unique
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  sync_status  String   @default("PENDING")
  store        Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@map("cctv_connections")
}

model AiApiKey {
  id             Int      @id @default(autoincrement())
  user_id        Int      
  engine         String   @default("OPENAI") 
  encrypted_key  String   @db.Text
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, engine])
  @@index([user_id])
  @@map("ai_api_keys")
}

model ChatSession {
  id           Int      @id @default(autoincrement())
  user_id      Int
  store_id     Int
  title        String   @default("New Chat")
  engine       String   @default("OPENAI")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  store        Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  messages     ChatMessage[]
  feedbacks    RlFeedback[]

  @@index([user_id, store_id])
  @@map("chat_sessions")
}

model ChatMessage {
  id              Int      @id @default(autoincrement())
  session_id      Int
  role            String   
  content         String   @db.Text
  source_ratio    Json?    
  created_at      DateTime @default(now())
  session         ChatSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@map("chat_messages")
}

model RlFeedback {
  id              Int      @id @default(autoincrement())
  session_id      Int
  message_id      Int?
  rating          Int      
  feedback_text   String?  @db.Text
  created_at      DateTime @default(now())
  session         ChatSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@map("rl_feedbacks")
}

model WeeklyReport {
  id             Int      @id @default(autoincrement())
  store_id       Int
  report_date    DateTime @db.Date
  year           Int
  week_number    Int
  content_json   Json
  pdf_url        String?
  created_at     DateTime @default(now())
  store          Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@unique([store_id, year, week_number])
  @@index([store_id])
  @@map("weekly_reports")
}

enum Role {
  OWNER
  MANAGER
  STAFF
}
